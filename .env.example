# Backend Configuration

# Environnement
NODE_ENV=development

# Serveur
PORT=3000

# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/quiz_musical?schema=public"

# JWT Authentication
JWT_SECRET=votre_secret_jwt_super_securise_a_changer
JWT_EXPIRES_IN=7d

# AWS S3 (ou MinIO local)
AWS_S3_BUCKET=quiz-musical-files
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=votre_access_key
AWS_SECRET_ACCESS_KEY=votre_secret_key
# Pour MinIO local :
# AWS_ENDPOINT=http://localhost:9000

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Socket.io Configuration
SOCKET_CORS_ORIGIN=http://localhost:5173

# Upload Limits
MAX_AUDIO_SIZE_MB=5
MAX_IMAGE_SIZE_MB=2

# Session Configuration
SESSION_MAX_PLAYERS=100
SESSION_EXPIRY_HOURS=2

# Monitoring (optionnel)
SENTRY_DSN=
DATADOG_API_KEY=

# Email (optionnel pour notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
