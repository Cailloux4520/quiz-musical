# Variables d'environnement pour Docker Compose
# Copiez ce fichier en .env et modifiez les valeurs pour la production

# PostgreSQL
POSTGRES_USER=quizuser
POSTGRES_PASSWORD=changez-ce-mot-de-passe-en-production
POSTGRES_DB=quizmusical
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changez-ce-mot-de-passe-en-production
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=quiz-media

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=changez-ce-mot-de-passe-en-production
